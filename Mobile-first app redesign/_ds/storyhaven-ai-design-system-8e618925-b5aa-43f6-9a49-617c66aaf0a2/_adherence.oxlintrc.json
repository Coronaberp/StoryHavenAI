{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/storyhaven-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Aptos Mono|Fraunces|Inter))/i]",
        "message": "Font not provided by the design system. Available: Aptos Mono, Fraunces, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:always|key|global)$/]",
        "message": "<Badge> variant must be one of 'always' | 'key' | 'global'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|active|icon|iconRight|disabled|type|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, active, icon, iconRight, disabled, type, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|danger|stop|ghost)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'danger' | 'stop' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CharacterCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|tagline|image|author|chats|tags|mono|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CharacterCard> doesn't accept that prop. Declared props: name, tagline, image, author, chats, tags, mono, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|name|children|style|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, name, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:ai|you)$/]",
        "message": "<ChatBubble> role must be one of 'ai' | 'you'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|onSend|sending|style|key|ref|className|style|children)$/]",
        "message": "<Composer> doesn't accept that prop. Declared props: placeholder, value, onChange, onSend, sending, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|style|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|muted)$/]",
        "message": "<Eyebrow> tone must be one of 'accent' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|size|title|ariaLabel|disabled|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: active, size, title, ariaLabel, disabled, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|onClose|footer|wide|children|style|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, title, onClose, footer, wide, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|style|children|key|ref|className|style|children)$/]",
        "message": "<ModeBadge> doesn't accept that prop. Declared props: mode, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeBadge'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:character|rpg)$/]",
        "message": "<ModeBadge> mode must be one of 'character' | 'rpg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: value, defaultValue, placeholder, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|style|children|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: value, label, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|checked|defaultChecked|nsfw|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, hint, checked, defaultChecked, nsfw, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|style|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant, size, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|gold)$/]",
        "message": "<Tag> variant must be one of 'default' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|multiline|rows|value|defaultValue|placeholder|hint|counter|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, multiline, rows, value, defaultValue, placeholder, hint, counter, disabled, onChange, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
